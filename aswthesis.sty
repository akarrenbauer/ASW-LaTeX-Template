\makeatletter
\def\configcommand#1#2{%
\expandafter\def\csname #1\endcsname##1{\expandafter\gdef\csname @#1\endcsname{##1}}%
\expandafter\def\csname @#1\endcsname{#2} % Standardwert = leer
}
\makeatother

\ExplSyntaxOn
\bool_new:N \l_aswthesis_file_has_content_bool
\ior_new:N \l_aswthesis_content_ior
\tl_new:N \l_aswthesis_content_line_tl
\NewDocumentCommand{\aswthesisfilehascontentTF}{mmm}
  {
    \bool_set_false:N \l_aswthesis_file_has_content_bool
    \ior_open:Nn \l_aswthesis_content_ior { #1 }
    \ior_str_map_inline:Nn \l_aswthesis_content_ior
      {
        \tl_set:Nx \l_aswthesis_content_line_tl { \tl_trim_spaces:n { ##1 } }
        \tl_if_empty:NF \l_aswthesis_content_line_tl
          {
            \str_if_eq:eeF
              { \tl_head:N \l_aswthesis_content_line_tl }
              { \c_percent_str }
              {
                \bool_set_true:N \l_aswthesis_file_has_content_bool
                \ior_map_break:
              }
          }
      }
    \ior_close:N \l_aswthesis_content_ior
    \bool_if:NTF \l_aswthesis_file_has_content_bool { #2 } { #3 }
  }
\ExplSyntaxOff

