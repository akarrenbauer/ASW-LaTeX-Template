% -------- Titelseiten -----------------------------------------
\makeatletter
\newcommand{\aswthesis@classictitlepage}{%
  \newgeometry{top=20mm,bottom=25mm}%
  \pagenumbering{alph}%
  \begin{titlepage}
    \begin{figure}[t]
      \begin{adjustwidth}{-\oddsidemargin-1in}{-\rightmargin}
        \minipage{0pt}
          \noindent
          \makebox[0pt][l]{%
            \raisebox{-\totalheight}[0pt][0pt]{%
              \includegraphics[width=\paperwidth]{titlepage/banner_top}%
            }%
          }%
        \endminipage

        \vspace*{10mm}
        \minipage{0.075\paperwidth}
          \hfill
        \endminipage
        \minipage{0.2475\paperwidth}
          \includegraphics[width=\linewidth]{titlepage/logo_asw_rgb}%
        \endminipage
        \minipage{0.275\paperwidth}
          \hfill
        \endminipage
        \minipage{0.2475\paperwidth}
          \aswthesis@ifcompanylogoTF{%
            \aswthesis@companylogo{\linewidth}%
          }{%
            \hfill
          }%
        \endminipage
      \end{adjustwidth}
    \end{figure}

    \vspace*{2cm}

    \begin{flushleft}
      \Huge
      \textbf{\@title}%
      \ifdefvoid{\@subtitle}{%
        \\[2cm]
      }{%
        \\[0.5cm]
        \LARGE
        \@subtitle\\[1.5cm]
      }%

      \LARGE
      {\@author}\\[0.5cm]

      \large
      Matrikelnummer: \@Matrikelnummer \\[0.5cm]

      \Large
      \varArbeit{} im Studiengang\\
      \@Studiengang
    \end{flushleft}

    \vspace{0.5cm}

    \begin{flushright}
      \ifdefvoid{\@Betreuer}{}{%
        \@BetreuerBezeichnung\\
        \@Betreuer\\[0.5cm]
      }%

      \@GutachterBezeichnung\\
      \@Gutachter\\[0.5cm]

      Eingereicht am \@eingereicht
    \end{flushright}

    \begin{figure}[b]
      \begin{adjustwidth}{-\oddsidemargin-1in}{-\rightmargin}
        \noindent
        \makebox[0pt][l]{%
          \raisebox{-\totalheight}[0pt][0pt]{%
            \includegraphics[width=\paperwidth]{titlepage/banner_bottom}%
          }%
        }%
      \end{adjustwidth}
    \end{figure}
  \end{titlepage}
  \restoregeometry
}

\newcommand{\aswthesis@moderntitlepage}{%
  \pagenumbering{alph}%
  \begin{titlepage}
    \newcommand{\HRule}{\rule{\linewidth}{0.5mm}}%
    \centering
    \vspace*{1cm}

    \textsc{\phantom{\LARGE ASW -- Akademie der Saarwirtschaft}}\\[1.5cm]
    \textsc{\Large \varArbeit}\\[0.5cm]
    \textsc{\large \@Studiengang}\\[0.5cm]

    \HRule\\[1cm]

    {\huge\bfseries\@title}\\[0.6cm]
    \ifdefvoid{\@subtitle}{}{%
      {\Large\@subtitle}\\[0.6cm]
    }%

    \HRule\\[1cm]

    {\Large \@author}\\[0.5cm]
    \textsc{\large Matrikelnummer: \@Matrikelnummer}\\[2cm]

    \begin{minipage}{0.43\textwidth}
      \begin{flushleft}
        \large
        \textit{\@BetreuerBezeichnung}\\
        \@Betreuer
      \end{flushleft}
    \end{minipage}
    ~
    \begin{minipage}{0.43\textwidth}
      \begin{flushright}
        \large
        \textit{\@GutachterBezeichnung}\\
        \@Gutachter
      \end{flushright}
    \end{minipage}

    \vspace{0.5cm}

    \begin{figure}[!h]
      \centering
      \aswthesis@ifcompanylogoTF{%
        \minipage{0.3\textwidth}
          \aswthesis@companylogo{\linewidth}%
        \endminipage
        \minipage{0.25\textwidth}
          \hfill
        \endminipage
      }%
      \minipage{0.35\textwidth}
        \includegraphics[width=\linewidth]{titlepage/logo_asw_rgb}%
      \endminipage
    \end{figure}

    \vfill\vfill

    \large\@eingereicht

    \vfill
  \end{titlepage}
}

\newcommand{\aswtitlepage}{%
  \ifdefstring{\aswthesis@titlepage}{modern}{%
    \aswthesis@moderntitlepage
  }{%
    \ifdefstring{\aswthesis@titlepage}{classic}{%
      \aswthesis@classictitlepage
    }{%
      \PackageWarning{aswthesis}{Unknown titlepage option `\aswthesis@titlepage'. Falling back to classic}%
      \aswthesis@classictitlepage
    }%
  }%
}
\makeatother

% -------- Dokumentrahmen --------------------------------------
\makeatletter
\newcommand{\aswthesis@inputblockingnote}[1]{%
  \IfFileExists{#1}{%
    \aswthesisfilehascontentTF{#1}{%
      \setstretch{1.2}%
      \input{#1}%
      \setstretch{1}%
      \pagebreak
    }{}%
  }{}%
}

\newcommand{\aswthesis@blockingnote}{%
  \ifdefempty{\aswthesis@blockingnotefile}{%
    \ifaswthesis@blockingnote
      \PackageWarning{aswthesis}{Option `blockingnote' is deprecated. Use `blockingnotefile=environment/sperrvermerk.tex'}%
      \aswthesis@inputblockingnote{environment/sperrvermerk.tex}%
    \fi
  }{%
    \aswthesis@inputblockingnote{\aswthesis@blockingnotefile}%
  }%
}

\newcommand{\aswthesis@frontmatter}{%
  \aswtitlepage{}%
  \newpage

  \pagenumbering{Roman}%

  \aswthesis@blockingnote

  \tableofcontents
  \newpage

  \iftotalfigures
    \listoffigures
  \fi

  \iftotaltables
    \listoftables
  \fi

  \iftotallstlistings
    \addcontentsline{toc}{section}{Listingverzeichnis}%
    \lstlistoflistings
  \fi
  \newpage

  \addcontentsline{toc}{section}{Abkürzungsverzeichnis}%
  \setstretch{0.5}%
  \printnoidxglossary[type=acronym,sort=letter,style=listdotted,title=Abkürzungsverzeichnis]%
  \newpage

  \pagenumbering{arabic}%
  \setstretch{1.2}%
}

\newcommand{\aswthesis@embedconfiguredfile}{%
  \ifdefempty{\aswthesis@embedfile}{}{%
    \IfFileExists{\aswthesis@embedfile}{%
      \embedfile[
        mimetype={application/zip},
        afrelationship={/Supplement}
      ]{\aswthesis@embedfile}%
    }{}%
  }%
}

\newcommand{\aswthesis@appendix}{%
  \ifdefempty{\aswthesis@appendixfile}{}{%
    \IfFileExists{\aswthesis@appendixfile}{%
      \aswthesisfilehascontentTF{\aswthesis@appendixfile}{%
        \clearpage
        \appendix
        \input{\aswthesis@appendixfile}%
        \clearpage
      }{}%
    }{}%
  }%
}

\newcommand{\aswthesis@declaration}{%
  \ifdefempty{\aswthesis@declarationfile}{%
    \PackageError{aswthesis}{Missing declarationfile option}{%
      The personal declaration is mandatory. Set declarationfile=<path>.%
    }%
  }{%
    \IfFileExists{\aswthesis@declarationfile}{%
      \aswthesisfilehascontentTF{\aswthesis@declarationfile}{%
        \input{\aswthesis@declarationfile}%
      }{%
        \PackageError{aswthesis}{Declaration file `\aswthesis@declarationfile' has no printed content}{%
          The personal declaration is mandatory. Add printable content to the file.%
        }%
      }%
    }{%
      \PackageError{aswthesis}{Declaration file `\aswthesis@declarationfile' not found}{%
        The personal declaration is mandatory. Check the declarationfile option.%
      }%
    }%
  }%
}

\newcommand{\aswthesis@backmatter}{%
  \clearpage
  \printbibliography[heading=bibintoc]%
  \clearpage

  \aswthesis@appendix

  \pagenumbering{gobble}%
  \aswthesis@declaration

  \aswthesis@embedconfiguredfile
}
\makeatother

\makeatletter
\AddToHook{begindocument/end}{\aswthesis@frontmatter}
\AddToHook{enddocument}{\aswthesis@backmatter}
\makeatother

