% ===================== thesisstyle.sty =====================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{aswthesis}[2025/10/07 v1.0 Vorlage für wissenschaftliche Arbeiten an der ASW gGmbH]

% -------- Optionen (kvoptions) --------------------------------
\RequirePackage{kvoptions}
\SetupKeyvalOptions{family=thesis,prefix=aswthesis@}

% Anpassen per Paketoption:
%   bibfile=<pfad zur .bib> (Default: references.bib)
%   imagespath=<bilderpfad/> (Default: images/)
%   titlepage=classic/modern (Default: classic)
%   blockingnotefile=<pfad zum Sperrvermerk> (Default: leer)
%   appendixfile=<pfad zur Anhang-Datei> (Default: leer)
%   declarationfile=<pfad zur persönlichen Erklärung> (Default: environment/pers_erklaerung.tex)
%   embedfile=<pfad zur einzubettenden Datei> (Default: leer)
%   companylogofile=<pfad zum Unternehmenslogo> (Default: leer)
%   showtitlesinlists=true/false (Default: true)
%   noparenthesesaroundyear=true/false      (Default: false)  -> Jahreszahl ohne Klammern im Lit.-Verz.
%   pdfa=true/false             (Default: true)   -> PDF/A-Konfiguration inkl. ICC-Profil
\DeclareStringOption[references.bib]{bibfile}
\DeclareStringOption[images/]{imagespath}
\DeclareStringOption[classic]{titlepage}
\DeclareStringOption[]{blockingnotefile}
\DeclareStringOption[]{appendixfile}
\DeclareStringOption[environment/pers_erklaerung.tex]{declarationfile}
\DeclareStringOption[]{embedfile}
\DeclareStringOption[]{companylogofile}
\DeclareBoolOption[true]{showtitlesinlists}
\DeclareBoolOption[false]{noparenthesesaroundyear}
\DeclareBoolOption[false]{blockingnote}
\DeclareBoolOption[true]{pdfa}
\DeclareStringOption[ptm]{rmdefault}
\DeclareStringOption[Bachelorarbeit]{thesis}
\ProcessKeyvalOptions*

